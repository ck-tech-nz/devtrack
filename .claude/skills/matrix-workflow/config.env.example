# matrix-workflow skill — personal tokens (copy to config.env and fill in).
# config.env is gitignored; do not commit real tokens.

# Sentry (required for `s<N>` / sentry#<N> source)
# SENTRY_TOKEN must be an API auth token (Bearer-compatible), NOT an OAuth app Client ID.
# Get it from: {SENTRY_BASE_URL}/settings/account/api/auth-tokens/  (Personal Tokens)
# Required scope: event:read (and org:read). Tokens typically start with sntryu_ / sntrys_.
SENTRY_BASE_URL=https://sentry.matrixai.xin
SENTRY_TOKEN=
SENTRY_ORG=matrix-ai

# DevTrack (required for `d<N>` / devtrakr#<N> source)
# DEVTRAKR_BASE_URL: site root, no trailing slash (script appends /api/external/issues/{id}/)
# DEVTRAKR_TOKEN: external API key created in DevTrack's Django admin (Bearer-compatible)
DEVTRAKR_BASE_URL=
DEVTRAKR_TOKEN=

# Notification webhook(s) — optional until notify.sh is wired
# SLACK_WEBHOOK_URL=
# FEISHU_WEBHOOK_URL=
