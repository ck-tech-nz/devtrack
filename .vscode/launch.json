{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django",
      "type": "debugpy",
      "request": "launch",
      "args": ["runserver", "0.0.0.0:8100"],
      "django": true,
      "autoStartBrowser": false,
      "program": "${workspaceFolder}/backend/manage.py"
    },
    {
      "name": "Vue",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nuxt", "dev", "--host", "0.0.0.0"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://[^:]+:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Celery Worker",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "celery", "-A", "config", "worker", "-l", "info", "--concurrency=2"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "全栈启动 (Django + Vue)",
      "configurations": ["Django", "Vue"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "1_fullstack",
        "order": 1
      }
    },
    {
      "name": "全栈启动 (Django + Vue + Celery)",
      "configurations": ["Django", "Vue", "Celery Worker"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "1_fullstack",
        "order": 2
      }
    }
  ]
}
